            // Remove browser extension attributes before React hydration
            function cleanupExtensionAttributes() {
              const attributesToRemove = [
                'cz-shortcut-listen',
                'data-new-gr-c-s-check-loaded', 
                'data-gr-ext-installed',
                'data-lt-tmp-id',
                'spellcheck',
                'data-gramm',
                'data-gramm_editor',
                'data-enable-grammarly'
              ];
              
              attributesToRemove.forEach(function(attr) {
                if (document.body && document.body.hasAttribute(attr)) {
                  document.body.removeAttribute(attr);
                }
              });
            }
            
            // Clean up immediately when DOM is ready
            if (document.readyState === 'loading') {
              document.addEventListener('DOMContentLoaded', cleanupExtensionAttributes);
            } else {
              cleanupExtensionAttributes();
            }
            
            // Clean up before React hydration
            if (typeof window !== 'undefined') {
              window.addEventListener('load', cleanupExtensionAttributes);
            }
